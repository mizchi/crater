{
  "modules": [
    "css-flexbox",
    "css-grid",
    "css-tables",
    "css-display",
    "css-box",
    "css-sizing",
    "css-align",
    "css-position",
    "css-overflow",
    "css-contain",
    "css-variables",
    "filter-effects",
    "compositing",

    // Near-term expansion: already close to current layout engine and WPT harness.
    "css-logical",
    "css-content",
    "css-multicol",
    "css-break",

    // Paint-leaning modules enabled as per-module baseline anchors. The
    // layout-tree compare runner mostly ignores color / paint properties,
    // so the pass rate measures layout robustness on these suites.
    // See pkspec compat.css-color-baseline, compat.css-backgrounds-baseline,
    // and compat.css-transforms-baseline.
    "css-color",
    "css-backgrounds",
    "css-transforms",

    // Logical-flow module. The wpt.json includePrefixes filter exposes
    // about 27 fixtures that the layout-tree compare runner can grade.
    // See pkspec compat.css-writing-modes-baseline.
    "css-writing-modes",

    // Pseudo-elements; only 1 fixture matches the current
    // includePrefixes filter. Widening the filter requires the broader
    // inline-model pass. See pkspec compat.css-pseudo-baseline.
    "css-pseudo",

    // Borders. The includePrefixes filter exposes a small set of
    // border-radius / border-shape / border-image fixtures (5 layout
    // comparable). See pkspec compat.css-borders-baseline.
    "css-borders",

    // Ruby module. The global includePrefixes filter matches no ruby
    // fixtures, so a dedicated modulePrefixes entry below exposes the
    // full css-ruby suite to the layout-tree compare runner.
    // See pkspec compat.css-ruby-baseline.
    "css-ruby",

    // Text module. Huge suite (~1867 fixtures across 28 subdirs); the
    // initial baseline anchors on the text-indent + tab-size properties
    // via the recursive modulePrefixes entry below. Widening to further
    // css-text properties is follow-up work.
    // See pkspec compat.css-text-baseline.
    "css-text",

    // Inline module. The global includePrefixes filter matches no inline
    // fixtures, so the modulePrefixes entry below exposes the top-level
    // css-inline suite (empty-span struts, inheritance, crashtests) to the
    // layout-tree compare runner. Subdirectories (model, parsing,
    // initial-letter, ...) are follow-up. See pkspec compat.css-inline-baseline.
    "css-inline",

    // Values & units module. The huge suite is mostly testharness
    // computed-value tests; the modulePrefixes entry below exposes the
    // layout-comparable calc() fixtures (sizing, offsets, margins, table,
    // text-indent, ...) to the layout-tree compare runner. Unblocked by the
    // mixed calc() support in mizchi/css 0.4.2 (issue #67) and the
    // fixed-table column-width expansion fix (issue #281).
    // See pkspec compat.css-values-baseline.
    "css-values",

    // Images module. The modulePrefixes [""] entry below exposes the
    // top-level css-images suite (gradients, object-fit / object-position,
    // object-view-box, cross-fade) to the layout-tree compare runner;
    // isScriptHarnessTest filters out the testharness computed-value tests.
    // Gradient painting is layout-trivial, so the pass rate measures
    // replaced-element sizing robustness. The #68 outliers (gradients-with-
    // border box-sizing, sibling-index() support) are fixed. Subdirectories
    // (gradient / image-set / animation / image-orientation / parsing) are
    // follow-up. See pkspec compat.css-images-baseline and issues #65 / #68.
    "css-images"
  ],
  "recursiveModules": [
    "css-align",
    "css-box",
    "css-text"
  ],
  "modulePrefixes": {
    "css-values": [
      "calc-"
    ],
    "css-images": [
      ""
    ],
    "css-inline": [
      ""
    ],
    "css-ruby": [
      ""
    ],
    "css-text": [
      "text-indent",
      "tab-size"
    ],
    "css-logical": [
      "logical-box-",
      "logicalprops-",
      "logical-values-",
      "block-size-",
      "inline-size-",
      "min-block-size-",
      "max-block-size-",
      "min-inline-size-",
      "max-inline-size-",
      "margin-block-",
      "margin-inline-",
      "padding-block-",
      "padding-inline-",
      "inset-"
    ],
    "css-content": [
      "content-",
      "pseudo-element-inline-box"
      // Later:
      // "quotes-",
      // "element-replacement-"
    ],
    "css-multicol": [
      "column-count-",
      "break-before-",
      "break-inside-",
      "balance-break-avoidance-"
      // Later:
      // "column-span-",
      // "column-balancing-",
      // "abspos-",
      // "balance-"
    ],
    "css-break": [
      "break-between-avoid-",
      "break-between-force-",
      "break-inside-avoid-",
      "margin-at-break-"
      // Later:
      // "orphans-",
      // "widows-",
      // "page-break-",
      // "break-at-end-"
    ]
  },
  "knownFailures": [
    // css-inline crashtest: passes "no crash" in browsers but the layout-tree
    // compare runner reports a mismatch; tracked as a css-inline residual.
    "inline-crash.html"
  ],
  "includePrefixes": [
    "align-", "place-",
    "align-content", "align-items", "align-self",
    "flex-", "justify-", "order-", "gap-",
    "scroll-", "scrollbar-", "scrollable-",
    "text-overflow-", "column-scroll-", "targeted-column-scroll-",
    "table-", "border-collapse", "border-spacing", "caption-side", "empty-cells", "visibility-collapse",
    "grid-", "subgrid-",
    "aspect-ratio", "block-size", "inline-size", "min-content", "max-content", "fit-content", "intrinsic", "contain-intrinsic",
    "margin-", "padding-", "border-", "box-sizing",
    "display-", "visibility-",
    "position-", "relative-", "sticky-", "fixed-",
    "clip-", "overflow-",
    "contain-",
    "var-", "variable-", "custom-property", "registered-", "css-variable", "inherit-", "fallback-",
    "filter-", "backdrop-filter", "mix-blend-mode", "isolation", "Blending"
  ]
}
