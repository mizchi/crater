  let gid = font.glyph_index(97)
  assert_true(gid > 0)
  let outline = font.glyph_outline(gid)
  let (w, h) = bbox_size(outline)
  assert_eq(w, 700)
  assert_eq(h, 700)
}

///|
test "cff_opcode/neg" {
  let data = Bytes::from_array(cff_opcode_neg_otf[:])
  guard parse_font(data) is Some(font)
  // glyph for lowercase a (codepoint 97)
  let gid = font.glyph_index(97)
  assert_true(gid > 0)
  let outline = font.glyph_outline(gid)
  let (w, h) = bbox_size(outline)
  assert_eq(w, 700)
  assert_eq(h, 700)
}

