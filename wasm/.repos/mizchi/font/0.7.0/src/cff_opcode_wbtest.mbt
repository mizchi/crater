///|
fn bbox_size(outline : Array[@svg.PathCommand]) -> (Int, Int) {
  let mut min_x = 1.0e9
  let mut min_y = 1.0e9
  let mut max_x = -1.0e9
  let mut max_y = -1.0e9
  for cmd in outline {
    match cmd {
      @svg.MoveTo(x, y) | @svg.LineTo(x, y) => {
        if x < min_x {
          min_x = x
        }
        if y < min_y {
          min_y = y
        }
        if x > max_x {
          max_x = x
        }
        if y > max_y {
          max_y = y
        }
      }
      @svg.CurveTo(_, _, _, _, x, y) => {
        if x < min_x {
          min_x = x
        }
        if y < min_y {
          min_y = y
        }
        if x > max_x {
          max_x = x
        }
        if y > max_y {
          max_y = y
        }
      }
      _ => ()
    }
  }
  ((max_x - min_x).to_int(), (max_y - min_y).to_int())
}

///|
test "cff_opcode/add" {
  let data = Bytes::from_array(cff_opcode_add_otf[:])
  guard parse_font(data) is Some(font)
  // glyph for lowercase a (codepoint 97)
  let gid = font.glyph_index(97)
  assert_true(gid > 0)
  let outline = font.glyph_outline(gid)
  let (w, h) = bbox_size(outline)
  assert_eq(w, 700)
  assert_eq(h, 700)
}

