{
  "description": "WPT WebDriver BiDi profiles for Crater CI",
  "version": "0.4.0",
  "default_skip_patterns": [
    "**/original_opener.py",
    "**/user_activation.py",
    "**/sandbox.py"
  ],
  "profiles": {
    "strict": {
      "description": "Known green targets used as strict CI gate",
      "targets": [
        "errors",
        "session/new",
        "session/status",
        "session/capabilities/unhandled_prompt_behavior/file",
        "session/subscribe/events.py",
        "session/subscribe/contexts.py",
        "session/subscribe/subscription_id.py",
        "session/subscribe/user_contexts.py",
        "session/subscribe/invalid.py",
        "session/unsubscribe/events.py",
        "session/unsubscribe/subscriptions.py",
        "session/unsubscribe/invalid.py",
        "browsing_context/get_tree",
        "browsing_context/context_created/context_created.py",
        "script/evaluate/invalid.py",
        "script/get_realms",
        "script/realm_created/realm_created.py",
        "script/realm_created/window_open.py"
      ],
      "quick": true,
      "timeout": 10
    },
    "network-no-auth": {
      "description": "Network compatibility sweep excluding auth-specific paths",
      "targets": [
        "network"
      ],
      "skip_patterns": [
        "network/auth_required/**",
        "network/continue_with_auth/**",
        "network/add_intercept/phase_auth_required.py",
        "network/continue_response/credentials.py"
      ],
      "quick": true,
      "timeout": 10
    }
  }
}
