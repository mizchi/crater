  new {
    name = "bidi_runtime_fetch_partition_cookie_bridge_wired"
    description =
      "The BiDi runtime fetch shim attaches partition cookies via a MoonBit-to-JS bridge. BidiProtocol::cookies_for_context_full_json aggregates the per-context jar; set_runtime_context_cookies pushes the snapshot into the JS realm; the JS shim's globalThis.__bidiResolveCookies(url) filters by URL and the fetch wrap injects the Cookie header when the caller has not supplied one. Covered by webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt."
    tags { "runtime"; "fetch"; "cookies"; "bidi" }
    specRef { "bug.runtime.fetch-no-partition-cookies" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_storage.mbt; grep -Fq -- \"fn BidiProtocol::cookies_for_context_full_json\" webdriver/webdriver/bidi_storage.mbt; test -f webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"js_set_runtime_context_cookies\" webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"fn set_runtime_context_cookies\" webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"globalThis.__bidiResolveCookies\" webdriver/webdriver/bidi_runtime_context.mbt; test -f webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"globalThis.__bidiResolveCookies\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"set_runtime_context_cookies\" webdriver/webdriver/bidi_protocol_context_lifecycle.mbt; test -f webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim attaches partition cookies to the actual outbound request\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim respects caller-provided Cookie header over bridge\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt'"
  }
  new {
    name = "bidi_runtime_fetch_preflight_dispatch_wired"
    description =
      "The BiDi runtime fetch shim sends OPTIONS preflight for non-simple cross-origin requests and validates ACA-Origin / ACA-Methods / ACA-Headers on the response. The wrap short-circuits the Promise.resolve.then chain for same-origin / no-CORS dispatch so simple requests still execute synchronously. Covered by webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt."
    tags { "runtime"; "fetch"; "cors"; "bidi" }
    specRef { "bug.runtime.fetch-no-cors-gate" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"maybeSendPreflight\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"corsSafelistedHeaders\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"Access-Control-Request-Method\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"Access-Control-Request-Headers\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"parseCsvAllowList\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"CORS preflight\" webdriver/webdriver/bidi_runtime_eval.mbt; test -f webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim sends CORS preflight for non-simple cross-origin requests\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim skips preflight for simple cross-origin GET\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim rejects when preflight omits ACA-Methods\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt'"
  }
  new {
    name = "bidi_navigate_wait_complete_async_bridge"
    description =
      "browsingContext.navigate { wait: \"complete\" } on http(s) URLs routes through js_navigate_and_send_async — a JS async bridge that awaits __loadPageWithScripts before sending the BiDi success response over the socket. The MoonBit dispatcher detects the http+wait=complete case via should_navigate_via_async_bridge, defers the runtime document load via apply_navigation_commit_state(defer_load: true), and hands the response off to the FFI. Data URL / about:blank / trickle-marker paths keep the existing sync sync_runtime_page path. Covered by webdriver/webdriver/bidi_navigate_wait_wbtest.mbt."
    tags { "bidi"; "navigation"; "webdriver"; "phase5" }
    specRef { "bug.bidi.navigate-wait-complete-returns-early" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"extern \\\"js\\\" fn js_navigate_and_send_async\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"await globalThis.__loadPageWithScripts\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"socket.send(payload)\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; test -f webdriver/webdriver/bidi_protocol_navigation_completion.mbt; grep -Fq -- \"fn BidiProtocol::should_navigate_via_async_bridge\" webdriver/webdriver/bidi_protocol_navigation_completion.mbt; grep -Fq -- \"defer_load : Bool\" webdriver/webdriver/bidi_protocol_navigation_completion.mbt; grep -Fq -- \"complete_navigation_request_with_wait_deferred\" webdriver/webdriver/bidi_protocol_navigation_completion.mbt; test -f webdriver/webdriver/bidi_protocol_browsing_context_navigate_dispatch.mbt; grep -Fq -- \"should_navigate_via_async_bridge\" webdriver/webdriver/bidi_protocol_browsing_context_navigate_dispatch.mbt; grep -Fq -- \"navigate_and_send_async(\" webdriver/webdriver/bidi_protocol_browsing_context_navigate_dispatch.mbt; test -f webdriver/webdriver/bidi_navigate_wait_wbtest.mbt; grep -Fq -- \"bidi navigate wait=complete on http URL takes deferred path\" webdriver/webdriver/bidi_navigate_wait_wbtest.mbt; grep -Fq -- \"bidi navigate wait=complete on data: URL still responds synchronously\" webdriver/webdriver/bidi_navigate_wait_wbtest.mbt'"
  }
  new {
    name = "bidi_navigate_http_url_not_parsed_prime_fix"
    description =
      "navigate_and_send_async primes the JS runtime via evaluate_js_with_console before invoking js_navigate_and_send_async, matching the pattern sync_runtime_page uses. Without priming, the first navigate after reset_runtime_js_state runs before __loadPageWithScripts is installed, causing the FFI to silently fall into the missing-loader branch. After the fix, the missing-loader branch also surfaces an explicit error instead of a silent success. Covered by webdriver/webdriver/bidi_navigate_wait_wbtest.mbt."
    tags { "bidi"; "navigation"; "webdriver"; "bug" }
    specRef { "bug.bidi.navigate-http-url-not-parsed" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"evaluate_js_with_console\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"Prime runtime helpers\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"runtime loader missing\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; grep -Fq -- \"success = false\" webdriver/webdriver/bidi_runtime_navigate_async.mbt; test -f webdriver/webdriver/bidi_navigate_wait_wbtest.mbt; grep -Fq -- \"navigate_and_send_async missing-loader branch sends error payload\" webdriver/webdriver/bidi_navigate_wait_wbtest.mbt'"
  }
  new {
    name = "bidi_runtime_set_cookie_inbound_ingest_wired"
    description =
      "BidiProtocol::persist_cookies_from_response parses Set-Cookie response headers and stores them in the partition jar scoped to the context's user_context + source_origin. The fetch shim's captureInboundSetCookies records each response's Set-Cookie array into globalThis.__bidiPendingCookieIngest; flush_pending_cookie_ingest drains this buffer back into MoonBit at every apply_effective_viewport_to_runtime_context boundary (matching the snapshot-push pattern used for outbound cookies). Closes bug.bidi.form-submit-no-followup-navigation: POST /login -> 302 + Set-Cookie -> GET /dashboard now arrives authenticated. Covered by webdriver/webdriver/bidi_runtime_set_cookie_ingest_wbtest.mbt."
    tags { "bidi"; "runtime"; "fetch"; "cookies"; "bug" }
    specRef { "bug.bidi.form-submit-no-followup-navigation" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_storage.mbt; grep -Fq -- \"fn BidiProtocol::persist_cookies_from_response\" webdriver/webdriver/bidi_storage.mbt; grep -Fq -- \"fn BidiProtocol::flush_pending_cookie_ingest\" webdriver/webdriver/bidi_storage.mbt; grep -Fq -- \"synthetic_network_parse_set_cookie_header_value\" webdriver/webdriver/bidi_storage.mbt; test -f webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"js_drain_pending_cookie_ingest\" webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"__bidiPendingCookieIngest\" webdriver/webdriver/bidi_runtime_context.mbt; test -f webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"captureInboundSetCookies\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"__bidiPendingCookieIngest\" webdriver/webdriver/bidi_runtime_eval.mbt; test -f webdriver/webdriver/bidi_protocol_context_lifecycle.mbt; grep -Fq -- \"flush_pending_cookie_ingest\" webdriver/webdriver/bidi_protocol_context_lifecycle.mbt; test -f webdriver/webdriver/bidi_runtime_set_cookie_ingest_wbtest.mbt; grep -Fq -- \"persist_cookies_from_response persists Set-Cookie into storage jar\" webdriver/webdriver/bidi_runtime_set_cookie_ingest_wbtest.mbt; grep -Fq -- \"fetch shim ingest buffer drain persists Set-Cookie into partition jar\" webdriver/webdriver/bidi_runtime_set_cookie_ingest_wbtest.mbt; grep -Fq -- \"fetch shim ingested cookie rides the outbound bridge on the next request\" webdriver/webdriver/bidi_runtime_set_cookie_ingest_wbtest.mbt'"
  }
  new {
    name = "bidi_runtime_fetch_preflight_cache_wired"
    description =
      "The BiDi runtime fetch shim memoizes validated OPTIONS responses in a per-realm preflightCache map keyed by `${origin}|${url}|${method}|${sortedHeaders}` (same cache_key formula as http/cors/cors.mbt PreflightCache) with the same [0, 7200]s Max-Age clamp. Repeat non-simple cross-origin requests within Max-Age skip the OPTIONS roundtrip. Cache entries whose allow-lists no longer cover the current request are evicted on hit and refetched. Covered by webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt."
    tags { "bidi"; "runtime"; "fetch"; "cors"; "preflight"; "performance" }
    specRef { "bug.runtime.fetch-preflight-cache-not-shared" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"__bidiPreflightCache\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"preflightCacheKey\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"preflightEntryCovers\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"expires_at_seconds\" webdriver/webdriver/bidi_runtime_eval.mbt; grep -Fq -- \"if (maxAge > 7200)\" webdriver/webdriver/bidi_runtime_eval.mbt; test -f webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim caches preflight result and skips second OPTIONS within Max-Age\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"fetch shim preflight cache evicts entry when new header is not covered\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt'"
  }
  new {
    name = "bidi_runtime_fetch_install_once_realm_reset"
    description =
      "reset_runtime_js_state in webdriver/webdriver/bidi_runtime_context.mbt drops __bidiFetchShimInstalled, __rawFetch, and __bidiPreflightCache so the next js_evaluate_expression bootstrap re-derives them from the current realm's globals. Without this drop, a browsingContext.create / destroy cycle that reuses the same JS realm would inherit the install-once flag and leave __rawFetch pointing at the previous session's stale stub. Covered by webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt."
    tags { "bidi"; "runtime"; "fetch"; "lifecycle" }
    specRef { "bug.runtime.fetch-install-once-realm-bound" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; test -f webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"delete globalThis.__bidiFetchShimInstalled\" webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"delete globalThis.__rawFetch\" webdriver/webdriver/bidi_runtime_context.mbt; grep -Fq -- \"delete globalThis.__bidiPreflightCache\" webdriver/webdriver/bidi_runtime_context.mbt; test -f webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt; grep -Fq -- \"reset_runtime_js_state lets next bootstrap rebind __rawFetch to the realm fetch\" webdriver/webdriver/bidi_runtime_fetch_wbtest.mbt'"
  }
