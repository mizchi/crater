amends "../pkspec/Test.pkl"

import "../tasks/bench.pkl" as bench
import "../tasks/browser.pkl" as browser
import "../tasks/check.pkl" as check
import "../tasks/core.pkl" as core
import "../tasks/diagnostics.pkl" as diagnostics
import "../tasks/release.pkl" as release
import "../tasks/spec.pkl" as spec
import "../tasks/test.pkl" as test
import "../tasks/visual.pkl" as visual
import "../tasks/wpt.pkl" as wpt

local function graphTaskPath(name: String, field: String): String =
  "tasks.#(name==\"" + name + "\")." + field

local publicGraphJson = "pkf graph --json"

local allGraphJson = "pkf graph --json --all"

tests {
  new {
    name = "pkfire_lists_default_task"
    description = "The default task should remain discoverable as the task inventory entrypoint."
    tags { "pkfire"; "smoke" }
    specRef { "task.default" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(core.default.name, "name")] = core.default.name
      [graphTaskPath(core.default.name, "kind")] = "task"
      [graphTaskPath(core.default.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_prepare_task"
    description = "The prepare gate should stay visible for pre-commit generated-file refreshes."
    tags { "pkfire"; "smoke" }
    specRef { "task.prepare" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(core.prepare.name, "name")] = core.prepare.name
      [graphTaskPath(core.prepare.name, "kind")] = "aggregate"
      [graphTaskPath(core.prepare.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_check_task"
    description = "The static validation gate should stay visible as check."
    tags { "pkfire"; "smoke" }
    specRef { "task.check" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(check.check.name, "name")] = check.check.name
      [graphTaskPath(check.check.name, "kind")] = "aggregate"
      [graphTaskPath(check.check.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_test_task"
    description = "The fast executable gate should stay visible as test."
    tags { "pkfire"; "smoke" }
    specRef { "task.test" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(test.test.name, "name")] = test.test.name
      [graphTaskPath(test.test.name, "kind")] = "aggregate"
      [graphTaskPath(test.test.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_bench_task"
    description = "Benchmark smoke and baseline checks should stay grouped under bench."
    tags { "pkfire"; "smoke" }
    specRef { "task.bench" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(bench.bench.name, "name")] = bench.bench.name
      [graphTaskPath(bench.bench.name, "kind")] = "aggregate"
      [graphTaskPath(bench.bench.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkspec_check_validates_declared_scenarios"
    description =
      "Approved crater scenarios should be linked to this Test module or explicit implementation pointers."
    tags { "pkspec"; "contract" }
    specRef { "spec.check" }
    workdir = ".."
    cmd = "pkspec spec --check --strict specs/crater.pkl specs/tasks.Test.pkl"
  }
  new {
    name = "pkfire_lists_spec_test_task"
    description = "The pkspec executable smoke suite should be exposed through pkfire."
    tags { "pkspec"; "pkfire"; "smoke" }
    specRef { "spec.test" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(spec.specTest.name, "name")] = spec.specTest.name
      [graphTaskPath(spec.specTest.name, "kind")] = "task"
      [graphTaskPath(spec.specTest.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_browser_compatibility_tasks"
    description = "DOM and locator compatibility work should have a browser-facing pkfire group."
    tags { "browser"; "playwright"; "pkfire" }
    specRef { "browser.playwright" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(browser.testBrowser.name, "name")] = browser.testBrowser.name
      [graphTaskPath(browser.testBrowser.name, "kind")] = "aggregate"
      [graphTaskPath(browser.testBrowser.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_preact_compatibility_task"
    description = "Preact compatibility checks should be independently discoverable."
    tags { "browser"; "preact"; "pkfire" }
    specRef { "browser.preact" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(browser.testPreact.name, "name")] = browser.testPreact.name
      [graphTaskPath(browser.testPreact.name, "kind")] = "task"
      [graphTaskPath(browser.testPreact.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_wpt_compatibility_tasks"
    description =
      "CSS, DOM, and WebDriver WPT compatibility checks should have a dedicated pkfire module."
    tags { "wpt"; "pkfire" }
    specRef { "wpt.css"; "wpt.dom"; "wpt.webdriver-bidi"; "wpt.suite" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(wpt.testWptCss.name, "name")] = wpt.testWptCss.name
      [graphTaskPath(wpt.testWptCss.name, "kind")] = "task"
      [graphTaskPath(wpt.testWptCss.name, "visibility")] = "public"
      [graphTaskPath(wpt.testWptDom.name, "name")] = wpt.testWptDom.name
      [graphTaskPath(wpt.testWptDom.name, "kind")] = "task"
      [graphTaskPath(wpt.testWptDom.name, "visibility")] = "public"
      [graphTaskPath(wpt.testWptWebdriver.name, "name")] = wpt.testWptWebdriver.name
      [graphTaskPath(wpt.testWptWebdriver.name, "kind")] = "task"
      [graphTaskPath(wpt.testWptWebdriver.name, "visibility")] = "public"
      [graphTaskPath(wpt.testWpt.name, "name")] = wpt.testWpt.name
      [graphTaskPath(wpt.testWpt.name, "kind")] = "aggregate"
      [graphTaskPath(wpt.testWpt.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_visual_regression_tasks"
    description =
      "Visual regression work should have a separate pkfire group from browser API compatibility."
    tags { "vrt"; "pkfire" }
    specRef { "vrt.report" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(visual.testVisual.name, "name")] = visual.testVisual.name
      [graphTaskPath(visual.testVisual.name, "kind")] = "aggregate"
      [graphTaskPath(visual.testVisual.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_lists_release_plan_tasks"
    description =
      "Release checks should expose publish-order validation and plan printing without publishing."
    tags { "release"; "pkfire" }
    specRef { "release.publish-order" }
    workdir = ".."
    cmd = publicGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(release.releasePlan.name, "name")] = release.releasePlan.name
      [graphTaskPath(release.releasePlan.name, "kind")] = "task"
      [graphTaskPath(release.releasePlan.name, "visibility")] = "public"
    }
  }
  new {
    name = "pkfire_marks_aggregate_dependencies_internal"
    description =
      "Leaf tasks that only implement public aggregate gates should stay hidden from the default task inventory."
    tags { "pkfire"; "contract" }
    specRef { "task.default" }
    workdir = ".."
    cmd = allGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(check.checkMoon.name, "visibility")] = "internal"
      [graphTaskPath(check.checkTs.name, "visibility")] = "internal"
      [graphTaskPath(spec.specCheck.name, "visibility")] = "internal"
      [graphTaskPath(bench.benchComponentVrt.name, "visibility")] = "internal"
      [graphTaskPath(test.testMoon.name, "visibility")] = "internal"
      [graphTaskPath(browser.testPlaywright.name, "visibility")] = "internal"
      [graphTaskPath(visual.testVrt.name, "visibility")] = "internal"
      [graphTaskPath(release.releaseCheck.name, "visibility")] = "internal"
    }
  }
  new {
    name = "pkfire_checks_affected_workflow_tests"
    description =
      "The affected task contract should verify direct input matches and expanded aggregate task plans."
    tags { "pkfire"; "affected"; "contract" }
    specRef { "task.affected" }
    workdir = ".."
    cmd = "pkf affected --check"
    expectStdoutContains {
      "workflow test(s) passed"
    }
  }
  new {
    name = "pkfire_lists_taskfile_diagnostics_tasks"
    description =
      "The Taskfile should expose pkfire lint, doctor, and long-list diagnostics without bloating the public task list."
    tags { "pkfire"; "diagnostics"; "contract" }
    specRef { "task.diagnostics" }
    workdir = ".."
    cmd = allGraphJson
    expectStdoutJsonPath {
      [graphTaskPath(check.checkTaskfile.name, "name")] = check.checkTaskfile.name
      [graphTaskPath(check.checkTaskfile.name, "kind")] = "task"
      [graphTaskPath(check.checkTaskfile.name, "visibility")] = "internal"
      [graphTaskPath(diagnostics.taskfileDiagnostics.name, "name")] =
        diagnostics.taskfileDiagnostics.name
      [graphTaskPath(diagnostics.taskfileDiagnostics.name, "kind")] = "aggregate"
      [graphTaskPath(diagnostics.taskfileDiagnostics.name, "visibility")] = "public"
      [graphTaskPath(diagnostics.taskfileLintJson.name, "visibility")] = "internal"
      [graphTaskPath(diagnostics.taskfileDoctorJson.name, "visibility")] = "internal"
      [graphTaskPath(diagnostics.taskfileAudit.name, "visibility")] = "internal"
      [graphTaskPath(diagnostics.taskfileDoctorFixPlan.name, "visibility")] = "internal"
    }
  }
  new {
    name = "ci_wires_pkfire_affected_with_cache"
    description =
      "The GitHub Actions CI should restore pkfire/Pkl caches and execute affected core gates against the resolved base."
    tags { "ci"; "pkfire"; "affected" }
    specRef { "ci.affected" }
    workdir = ".."
    cmd =
      "bash -lc 'set -e; for p in \"mizchi/pkfire@v0.10.0\" \"actions/cache@v4\" \"PKFIRE_CACHE_DIR\" \"~/.pkl/cache\" \"pkf pkl-cache warm\" \"scripts/ci/pkfire-affected-base.sh\" \"pkf affected\" \"--profile=ci\" \"check test test-taffy test-wasm test-native-smoke\"; do rg -q -- \"$p\" .github/workflows/ci.yml; done'"
  }
}
