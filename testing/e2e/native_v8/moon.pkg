import {
  "mizchi/crater-browser/shell",
  "mizchi/crater-browser-native/assets",
  "mizchi/crater-browser-native/js_v8",
  "mizchi/crater-browser-runtime" @js,
  "mizchi/crater-dom/dom",
}

warnings = "-text_segment_excceed-unused_package"

supported_targets = "+native"

options(
  link: { "native": { "cc-link-flags": "${build.MIZCHI_V8_CC_LINK_FLAGS}" } },
)
