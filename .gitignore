.DS_Store
target/
.mooncakes/
.moonagent/
taffy
target
.claude/settings.local.json

# Dependencies
node_modules/
**/.repos/

# Python
__pycache__/
*.pyc
.venv/
uv.lock

# WPT test temp directories
.wpt-temp/
.wpt-crater-conftest/
.wpt-reports/

# MoonBit generated files (tracked for publishing)
# *.generated.mbti

# Generated render results
render-results/

# Generated test fixtures (regenerate with npm run gentest)
fixtures/
!benchmarks/fixtures/
!benchmarks/fixtures/github_mizchi.html
!benchmarks/fixtures/github_primer.css
!benchmarks/fixtures/github_global.css
!benchmarks/fixtures/github_main.css
!benchmarks/fixtures/github_profile.css
!scripts/fixtures/
!scripts/fixtures/**

# WPT support files (CSS/fonts, regenerated during fetch)
wpt-tests/**/support/
.wpt-safe-subset-cache.json

# Real-world site downloads (regenerate with `just download-real-world-batch`).
# `example-com` is the one snapshot pinned to repo state because
# `tests/paint-vrt.test.ts` runs against it as a fixed visual-diff fixture.
real-world/*
!real-world/example-com/
real-world/example-com/*
!real-world/example-com/index.html
!real-world/example-com/meta.json
# hacker-news is pinned as a second match-rate fixture (a clean, table-based,
# server-rendered page). Re-capture with scripts/capture-real-world-fetch.ts.
!real-world/hacker-news/
real-world/hacker-news/*
!real-world/hacker-news/index.html
!real-world/hacker-news/meta.json

# WASM component transpiled output (regenerate with npm run build:wasm-component && npx jco transpile)
wasm/dist/

# Browser npm build output
browser/dist/
browser/tests/luna-vrt/output-text-masked/
browser/tests/luna-vrt/report-text-masked.json
output/

# MoonBit build output
_build/

# Local WPT investigation artifacts
tmp/
docs/private/
ci-logs/
test-results/
trace.json
browser/jsbidi/trace.json
.playwright-mcp/
.claude/*
!.claude/skills/
.flaker/
.tornado/
.bidi-ws-url
.cache/pkfire/
.cache/paint-vrt-reference/
.cache/wpt-vrt-reference/
