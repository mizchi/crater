///|
test "cff/parse_cff_index - empty" {
  let data = Bytes::from_array([b'\x00', b'\x00'])
  let reader = BinaryReader::new(data)
  let idx = parse_cff_index(reader)
  inspect(idx.count(), content="0")
}

///|
test "cff/parse_cff_index - single entry" {
  let data = Bytes::from_array([
    b'\x00', b'\x01', // count = 1
     b'\x01', // offSize = 1
     b'\x01', b'\x04', // offsets: 1, 4 (1-based)
     b'\xAA', b'\xBB', b'\xCC', // data (3 bytes)
  ])
  let reader = BinaryReader::new(data)
  let idx = parse_cff_index(reader)
  inspect(idx.count(), content="1")
  let (off, len) = idx.entry(0)
  inspect(len, content="3")
  inspect(off, content="5")
}

///|
test "cff/parse_cff_index - two entries" {
  let data = Bytes::from_array([
    b'\x00', b'\x02', // count = 2
     b'\x01', // offSize = 1
     b'\x01', b'\x03', b'\x06', // offsets: 1, 3, 6
     b'\x01', b'\x02', b'\x03', b'\x04', b'\x05',
  ])
  let reader = BinaryReader::new(data)
  let idx = parse_cff_index(reader)
  inspect(idx.count(), content="2")
  let (_, len0) = idx.entry(0)
  let (_, len1) = idx.entry(1)
  inspect(len0, content="2")
  inspect(len1, content="3")
}

///|
test "cff/parse_cff_dict - simple operand" {
  let data = Bytes::from_array([
      b'\x8B', // operand: 139 -> 0
       b'\x14',
    ], // operator: 20
  )
  let dict = parse_cff_dict(data, 0, 2)
  inspect(dict.get(20), content="Some([0])")
}

///|
test "cff/parse_cff_dict - negative operand" {
  let data = Bytes::from_array([
      b'\x27', // operand: 39 -> 39-139 = -100
       b'\x14',
    ], // operator: 20
  )
  let dict = parse_cff_dict(data, 0, 2)
  inspect(dict.get(20), content="Some([-100])")
}

///|
test "cff/parse_cff_dict - two operands" {
  let data = Bytes::from_array([
      b'\xEF', // operand: 239 -> 100
       b'\xF8', b'\x88', // operand: (248-247)*256 + 136 + 108 = 500
       b'\x12',
    ], // operator: 18
  )
  let dict = parse_cff_dict(data, 0, 4)
  inspect(dict.get(18), content="Some([100, 500])")
}

///|
test "cff/calc_subr_bias" {
  inspect(calc_subr_bias(0), content="107")
  inspect(calc_subr_bias(1239), content="107")
  inspect(calc_subr_bias(1240), content="1131")
  inspect(calc_subr_bias(33900), content="32768")
}

///|
test "cff/charstring_endchar_only" {
  let data = Bytes::from_array([b'\x0E'])
  let cff : CFFData = {
    charstrings: { data_offset: 0, offsets: [0, 1] },
    global_subrs: { data_offset: 0, offsets: [0] },
    local_subrs: { data_offset: 0, offsets: [0] },
    default_width_x: 0,
    nominal_width_x: 0,
    is_cff2: false,
    ivs: None,
  }
  let cmds = cff_glyph_outline(data, cff, 0)
  inspect(cmds, content="[]")
}

///|
test "cff/charstring_rmoveto_endchar" {
  let data = Bytes::from_array([
      b'\xEF', // 100
       b'\xF7', b'\x5C', // 200
       b'\x15', // rmoveto (21)
       b'\x0E',
    ], // endchar (14)
  )
  let cff : CFFData = {
    charstrings: { data_offset: 0, offsets: [0, 5] },
    global_subrs: { data_offset: 0, offsets: [0] },
    local_subrs: { data_offset: 0, offsets: [0] },
    default_width_x: 0,
    nominal_width_x: 0,
    is_cff2: false,
    ivs: None,
  }
  let cmds = cff_glyph_outline(data, cff, 0)
  inspect(cmds, content="[MoveTo(100, 200), ClosePath]")
}

///|
test "cff/charstring_simple_rect" {
  let data = Bytes::from_array([
    b'\x8B', b'\x8B', // 0, 0
     b'\x15', // rmoveto (21)
     b'\xEF', // 100
     b'\x06', // hlineto (6)
     b'\xBD', // 50
     b'\x07', // vlineto (7)
     b'\x27', // -100
     b'\x06', // hlineto (6)
     b'\x0E', // endchar (14)
  ])
  let cff : CFFData = {
    charstrings: { data_offset: 0, offsets: [0, 10] },
    global_subrs: { data_offset: 0, offsets: [0] },
    local_subrs: { data_offset: 0, offsets: [0] },
    default_width_x: 0,
    nominal_width_x: 0,
    is_cff2: false,
    ivs: None,
  }
  let cmds = cff_glyph_outline(data, cff, 0)
  inspect(
    cmds,
    content="[MoveTo(0, 0), LineTo(100, 0), LineTo(100, 50), LineTo(0, 50), ClosePath]",
  )
}

///|
test "cff/charstring_rrcurveto" {
  let data = Bytes::from_array([
    b'\x8B', b'\x8B', // 0, 0
     b'\x15', // rmoveto (21)
     b'\x95', b'\x9F', b'\xA9', b'\xB3', b'\xBD', b'\xC7', // 10,20,30,40,50,60
     b'\x08', // rrcurveto (8)
     b'\x0E', // endchar (14)
  ])
  let cff : CFFData = {
    charstrings: { data_offset: 0, offsets: [0, 11] },
    global_subrs: { data_offset: 0, offsets: [0] },
    local_subrs: { data_offset: 0, offsets: [0] },
    default_width_x: 0,
    nominal_width_x: 0,
    is_cff2: false,
    ivs: None,
  }
  let cmds = cff_glyph_outline(data, cff, 0)
  inspect(
    cmds,
    content="[MoveTo(0, 0), CurveTo(10, 20, 40, 60, 90, 120), ClosePath]",
  )
}

