///|
fn load_dictionary() -> Bytes {
  let chunks : Array[FixedArray[Byte]] = [
    dict_chunk_0, dict_chunk_1, dict_chunk_2, dict_chunk_3, dict_chunk_4, dict_chunk_5,
    dict_chunk_6, dict_chunk_7, dict_chunk_8, dict_chunk_9, dict_chunk_10, dict_chunk_11,
    dict_chunk_12, dict_chunk_13, dict_chunk_14, dict_chunk_15, dict_chunk_16, dict_chunk_17,
    dict_chunk_18, dict_chunk_19, dict_chunk_20, dict_chunk_21, dict_chunk_22, dict_chunk_23,
    dict_chunk_24, dict_chunk_25, dict_chunk_26, dict_chunk_27, dict_chunk_28, dict_chunk_29,
  ]
  let total = brotli_dictionary_size
  Bytes::makei(total, fn(idx) {
    let chunk_idx = idx / 4096
    let byte_idx = idx % 4096
    chunks[chunk_idx][byte_idx]
  })
}
