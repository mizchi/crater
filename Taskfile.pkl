amends "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl"

import "tasks/bench.pkl" as bench
import "tasks/browser.pkl" as browser
import "tasks/check.pkl" as check
import "tasks/core.pkl" as core
import "tasks/diagnostics.pkl" as diagnostics
import "tasks/release.pkl" as release
import "tasks/spec.pkl" as spec
import "tasks/test.pkl" as test
import "tasks/visual.pkl" as visual
import "tasks/wpt.pkl" as wpt

tasks {
  ...core.tasks
  ...check.tasks
  ...diagnostics.tasks
  ...spec.tasks
  ...test.tasks
  ...browser.tasks
  ...wpt.tasks
  ...visual.tasks
  ...bench.tasks
  ...release.tasks
}

workflowTests {
  new {
    name = "flaker config change runs full check gate"
    changed { "flaker.toml" }
    direct { check.checkFlaker.name }
    tasks {
      check.checkFlaker.name
      check.checkMbti.name
      check.checkMoon.name
      check.checkTaskfile.name
      check.checkTs.name
      spec.specCheck.name
      spec.specLint.name
      check.check.name
    }
  }
  new {
    name = "wpt vrt config change runs visual gate"
    changed { "wpt-vrt.json" }
    direct { visual.testWptVrt.name }
    tasks {
      visual.testVrt.name
      visual.testWptVrt.name
      visual.testVisual.name
    }
  }
  new {
    name = "wpt dom fixture change runs dom and visual gates"
    changed { "wpt/dom/nodes/Document-createElement.html" }
    direct {
      visual.testWptVrt.name
      wpt.testWptDom.name
    }
    tasks {
      visual.testVrt.name
      visual.testWptVrt.name
      visual.testVisual.name
      wpt.testWptCss.name
      wpt.testWptDom.name
      wpt.testWptWebdriver.name
      wpt.testWpt.name
    }
  }
  new {
    name = "wpt webdriver fixture change runs webdriver and visual gates"
    changed { "wpt/webdriver/tests/bidi/session/status/status.py" }
    direct {
      visual.testWptVrt.name
      wpt.testWptWebdriver.name
    }
    tasks {
      visual.testVrt.name
      visual.testWptVrt.name
      visual.testVisual.name
      wpt.testWptCss.name
      wpt.testWptDom.name
      wpt.testWptWebdriver.name
      wpt.testWpt.name
    }
  }
  new {
    name = "ci workflow change runs spec-backed core gates"
    changed { ".github/workflows/ci.yml" }
    direct {
      spec.specCheck.name
      spec.specLint.name
      spec.specDocs.name
      spec.specTest.name
    }
    tasks {
      check.checkFlaker.name
      check.checkMbti.name
      check.checkMoon.name
      check.checkTaskfile.name
      check.checkTs.name
      spec.specCheck.name
      spec.specLint.name
      check.check.name
      spec.specDocs.name
      spec.specTest.name
      spec.spec.name
      test.buildJsPackage.name
      test.testMoon.name
      test.testVitest.name
      test.testWasm.name
      test.testNode.name
      test.test.name
    }
  }
  new {
    name = "component bench baseline change runs bench gate"
    changed { "benchmarks/tests/component-vrt-bench-baseline.json" }
    direct {
      bench.benchComponentVrt.name
      bench.benchComponentBaseline.name
    }
    tasks {
      bench.benchComponentVrt.name
      bench.benchComponentBaseline.name
      bench.benchCraterCli.name
      bench.bench.name
    }
  }
}
