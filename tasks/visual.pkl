import "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl" as pkfire

import "sources.pkl" as src

testVrt: pkfire.Task = new {
  name = "test-vrt"
  description = "Run paint visual regression tests"
  visibility = "internal"
  cmd = "just test-vrt"
  inputs {
    ...src.nodeSources
    "tests/fixtures/**"
    "renderer/**/*.mbt"
    "renderer/**/*.mbti"
    "renderer/**/moon.pkg"
    "painter/**/*.mbt"
    "painter/**/*.mbti"
    "painter/**/moon.pkg"
  }
}

testWptVrt: pkfire.Task = new {
  name = "test-wpt-vrt"
  description = "Run WPT visual regression tests"
  visibility = "internal"
  cmd = "just test-wpt-vrt"
  inputs {
    ...src.wptToolchainSources
    "playwright.config.ts"
    "tests/wpt-vrt.test.ts"
    "wpt-vrt.json"
    "tests/wpt-vrt-baseline.json"
    "wpt/**"
  }
}

testVisual: pkfire.Task = new {
  name = "test-visual"
  description = "Run visual regression suites"
  cache = false
  deps { testVrt; testWptVrt }
}

testImageVrt: pkfire.Task = new {
  name = "test-image-vrt"
  description = "Run the browser-free PNG image-VRT baseline check"
  visibility = "internal"
  cmd = "just test-image-vrt"
  inputs {
    "renderer/gfx_frame/**/*.mbt"
    "renderer/gfx_image/**/*.mbt"
    "renderer/gfx_text/**/*.mbt"
    "renderer/gfx_bridge/**/*.mbt"
    "renderer/gfx_software/**/*.mbt"
    "renderer/gfx_vrt/**/*.mbt"
    "renderer/**/moon.pkg"
    "js/png_image.mbt"
    "js/moon.pkg"
    "js/scripts/image-vrt.mjs"
    "js/gfx-web-runtime.mjs"
    "js/scripts/webgpu-e2e.mjs"
    "js/scripts/accuracy.mjs"
    "js/test/image-vrt/baselines/**"
  }
}

tasks: Listing<pkfire.Task> = new {
  testVrt
  testWptVrt
  testVisual
  testImageVrt
}
