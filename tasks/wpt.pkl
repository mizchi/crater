import "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl" as pkfire

import "sources.pkl" as src

testWptCss: pkfire.Task = new {
  name = "test-wpt-css"
  description = "Run WPT CSS layout compatibility tests"
  cmd = "just wpt-all"
  inputs {
    ...src.wptToolchainSources
    "css/**/*.mbt"
    "css/**/*.mbti"
    "css/**/moon.pkg"
    "layout/**/*.mbt"
    "layout/**/*.mbti"
    "layout/**/moon.pkg"
    "painter/**/*.mbt"
    "painter/**/*.mbti"
    "painter/**/moon.pkg"
    "renderer/**/*.mbt"
    "renderer/**/*.mbti"
    "renderer/**/moon.pkg"
    "runtime/**/*.mbt"
    "runtime/**/*.mbti"
    "runtime/**/moon.pkg"
    "scripts/wpt-config.ts"
    "scripts/wpt-html-utils.ts"
    "scripts/wpt-runner.ts"
    "scripts/test-wpt-module-baseline.sh"
    "tests/wpt-baselines/**"
    "tests/wpt-baseline.env"
    "wpt.json"
    "wpt/css/**"
    "wpt/resources/**"
  }
}

testWptDom: pkfire.Task = new {
  name = "test-wpt-dom"
  description = "Run WPT DOM compatibility tests"
  cmd = "just wpt-dom-all"
  inputs {
    ...src.wptToolchainSources
    "dom/**/*.mbt"
    "dom/**/*.mbti"
    "dom/**/moon.pkg"
    "runtime/**/*.mbt"
    "runtime/**/*.mbti"
    "runtime/**/moon.pkg"
    "js/**/*.mbt"
    "js/**/*.mbti"
    "js/**/moon.pkg"
    "js/scripts/**/*.mjs"
    "scripts/wpt-dom-runner.ts"
    "wpt/dom/**"
    "wpt/domparsing/**"
    "wpt/resources/**"
  }
}

testWptWebdriver: pkfire.Task = new {
  name = "test-wpt-webdriver"
  description = "Run WPT WebDriver BiDi protocol tests"
  cmd = "just wpt-webdriver-all"
  inputs {
    ...src.wptToolchainSources
    "browser/**/*.mbt"
    "browser/**/*.mbti"
    "browser/**/moon.pkg"
    "browser/scripts/**/*.mjs"
    "testing/**/*.mbt"
    "testing/**/*.mbti"
    "testing/**/moon.pkg"
    "webdriver/**/*.mbt"
    "webdriver/**/*.mbti"
    "webdriver/**/moon.pkg"
    "scripts/wpt-bidi-subset.json"
    "scripts/wpt-webdriver-runner.ts"
    "wpt/webdriver/**"
  }
}

testWpt: pkfire.Task = new {
  name = "test-wpt"
  description = "Run WPT CSS, DOM, and WebDriver compatibility suites"
  cache = false
  deps { testWptCss; testWptDom; testWptWebdriver }
}

tasks: Listing<pkfire.Task> = new {
  testWptCss
  testWptDom
  testWptWebdriver
  testWpt
}
