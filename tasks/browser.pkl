import "package://pkg.pkl-lang.org/github.com/mizchi/pkfire/pkfire@0.10.0#/Taskfile.pkl" as pkfire

import "sources.pkl" as src

testPlaywright: pkfire.Task = new {
  name = "test-playwright"
  description = "Run Playwright adapter and user scenario tests"
  visibility = "internal"
  cmd = "just test-playwright-adapter"
  cache = false
  inputs {
    ...src.nodeSources
    "webdriver/**"
    "browser/**"
  }
}

testWebsite: pkfire.Task = new {
  name = "test-website"
  description = "Run website loading and browser user scenario tests"
  visibility = "internal"
  cmd = "just test-website"
  cache = false
  inputs {
    ...src.nodeSources
    "html_assets/**"
    "browser/**"
    "webdriver/**"
  }
}

testPreact: pkfire.Task = new {
  name = "test-preact"
  description = "Run Preact compatibility scenarios against the browser adapter"
  cmd = "just test-preact"
  cache = false
  inputs {
    ...src.nodeSources
    "browser/**"
    "dom/**"
    "runtime/**"
    "webdriver/**"
    "tests/preact-compat.test.ts"
  }
}

testWptDom: pkfire.Task = new {
  name = "test-wpt-dom"
  description = "Run WPT DOM compatibility tests"
  cmd = "just wpt-dom-all"
  cache = false
  inputs {
    ...src.nodeSources
    "dom/**"
    "runtime/**"
    "js/**"
    "scripts/wpt-dom-runner.ts"
    "wpt/dom/**"
    "wpt/domparsing/**"
    "wpt/resources/**"
  }
}

testWptWebdriver: pkfire.Task = new {
  name = "test-wpt-webdriver"
  description = "Run WPT WebDriver BiDi protocol tests"
  cmd = "just wpt-webdriver-all"
  cache = false
  inputs {
    ...src.nodeSources
    "browser/**"
    "testing/**"
    "webdriver/**"
    "scripts/wpt-bidi-subset.json"
    "scripts/wpt-webdriver-runner.ts"
    "wpt/webdriver/**"
  }
}

testBrowser: pkfire.Task = new {
  name = "test-browser"
  description = "Run browser-facing non-VRT compatibility suites"
  cache = false
  deps { testPlaywright; testWebsite; testPreact }
}

tasks: Listing<pkfire.Task> = new {
  testPlaywright
  testWebsite
  testPreact
  testWptDom
  testWptWebdriver
  testBrowser
}
