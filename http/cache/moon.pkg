import {
  "mizchi/crater-browser-http" @http,
  "moonbitlang/async/io" @async_io,
  "moonbitlang/async/js_async",
  "moonbitlang/core/double",
  "moonbitlang/core/json",
  "moonbitlang/core/string",
}

warnings = "-unused_package-unused_error_type"

supported_targets = "js+native+wasm+wasm-gc"

options(
  targets: {
    "cache_js.mbt": [ "js" ],
    "cache_native.mbt": [ "native" ],
    "cache_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
